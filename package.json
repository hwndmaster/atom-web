{
    "name": "atom-web",
    "version": "0.0.0",
    "private": true,
    "description": "pnpm monorepo for shared TypeScript/React/Redux packages",
    "scripts": {
        "build": "pnpm -r --workspace-concurrency=1 build",
        "test": "pnpm -r test",
        "lint": "pnpm -r lint",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "pnpm build && changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@types/node": "catalog:",
        "esbuild-sass-plugin": "^3.7.0",
        "sass": "catalog:",
        "typescript": "catalog:"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=9"
    }
}
